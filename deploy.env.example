# Copy to deploy.env and fill in. deploy.env is gitignored.
#
# Azure targets (used by ./deploy.sh)
AZURE_RESOURCE_GROUP=glunova-rg
AZURE_LOCATION=eastus
AZURE_ACR_NAME=glunovaacr
AZURE_CONTAINERAPPS_ENV=glunova-cae
AZURE_CONTAINERAPP_DJANGO=glunova-django
AZURE_CONTAINERAPP_FASTAPI=glunova-fastapi
# Optional override (default: short git SHA or timestamp)
# IMAGE_TAG=abc1234
