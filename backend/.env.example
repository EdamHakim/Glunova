# Copy to .env and fill in real values (never commit .env).

# PostgreSQL — Supabase: Project Settings → Database → URI (use Session mode or direct).
# Prefer explicit driver (psycopg v3). Bare postgresql:// is auto-rewritten to +psycopg in config.
DATABASE_URL=postgresql+psycopg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Or local Docker Postgres:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/glunova

# JWT signing (min 32 characters; generate with: openssl rand -hex 32)
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

APP_ENV=development
DEBUG=true

# Comma-separated origins for browser clients (Next.js dev server, etc.)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=20/minute

# Medical documents (OCR) — local file storage (gitignored uploads/)
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=10
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# LLM refinement after rule extraction: groq | ollama
LLM_PROVIDER=groq
# Groq (OpenAI-compatible). PHI: confirm vendor compliance before production.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Ollama (self-hosted)
# LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

LLM_TIMEOUT_SECONDS=60
LLM_MAX_OCR_CHARS=12000
