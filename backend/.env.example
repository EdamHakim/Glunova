# Glunova hybrid backend — copy to backend/.env and edit.
#
#   cp backend/.env.example backend/.env        (macOS / Linux)
#   copy backend\.env.example backend\.env      (Windows CMD)
#
# Django and FastAPI both read backend/.env (see backend/django_app/core/settings.py
# and backend/fastapi_ai/core/config.py).

# --- Required ---
DATABASE_URL=postgresql://glunova:glunova@localhost:5432/glunova

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
# Comma-separated browser origins for CORS (defaults include http://localhost:3000 if unset)
FRONTEND_ORIGINS=http://localhost:3000

# JWT signing — optional; Django defaults to DJANGO_SECRET_KEY. Set explicitly to match FastAPI in production.
# JWT_SHARED_SECRET=same-value-as-django-secret-or-dedicated-signing-secret

# Django calls FastAPI — use 127.0.0.1 when running runserver + uvicorn on the host (not Docker hostname)
AI_SERVICE_URL=http://127.0.0.1:8001
FASTAPI_BASE_URL=http://127.0.0.1:8001

# --- Groq (FastAPI: LLM / vision routes) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: document uploads (Supabase) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_STORAGE_BUCKET=medical-documents

# --- Optional: Qdrant (psychology RAG / memory) ---
# QDRANT_URL=
# QDRANT_API_KEY=

# --- Optional: psychology voice (ElevenLabs TTS) ---
# ELEVENLABS_API_KEY=

# --- Optional: Hugging Face (HF_TOKEN or HUGGINGFACE_HUB_TOKEN for pipelines / inference) ---
# HF_TOKEN=

# --- Optional: Azure Document Intelligence (OCR) ---
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# AZURE_DOCUMENT_INTELLIGENCE_KEY=
